# vLLM (Qwen3.5 local endpoint)
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL_NAME=Qwen/Qwen2.5-7B-Instruct
VLLM_API_KEY=token-abc123

# LLM provider switch: "vllm" (default) or "azure"
LLM_PROVIDER=vllm
# Optional: keep temperature at 0 for reproducibility
LLM_TEMPERATURE=0

# Azure OpenAI (for testing)
# Example values (you must fill yours):
# AZURE_OPENAI_ENDPOINT=https://<your-resource-name>.openai.azure.com/
# AZURE_OPENAI_API_KEY=<your-azure-openai-key>
# AZURE_OPENAI_API_VERSION=2024-02-15-preview
# AZURE_OPENAI_DEPLOYMENT_NAME=<your-deployment-name>

# ChromaDB (retrieval + benchmark ingest only; Q&A is not written back to Chroma)
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION_PAPERS=research_memory
# Legacy / unused by pipeline: answers go to Redis conversation lists instead
CHROMA_COLLECTION_QA=qa_memory

# Redis (LangGraph checkpoint + conversation history LIST conv:{session_id})
REDIS_URL=redis://localhost:6379
# Prefix for LIST keys; stored_memory_id uses the same prefix
REDIS_CONV_PREFIX=conv:

# Embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2

# RAG settings
TOP_K_CHUNKS=5

# Metrics
METRICS_LOG_PATH=metrics_log.jsonl

# Benchmark
BENCHMARK_DATASET=ai-hyz/MemoryAgentBench
BENCHMARK_SPLIT=Accurate_Retrieval

# LangSmith (optional tracing — enable when you have an API key)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=memory-agent
